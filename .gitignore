# --- Python backend ---
backend/venv/
backend/.venv/
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# --- Node / frontend ---
node_modules/
ui/dist/
ui/.vite/

# --- Tauri / Rust ---
ui/src-tauri/target/
ui/src-tauri/gen/

# --- Packaging spike artifacts ---
packaging/spike/build/
packaging/spike/dist/
packaging/spike/*.spec

# --- Eva runtime data (never committed; user's private vault) ---
local_vault/

# --- Model weights (multi-GB; fetched first-run via scripts/download_model_mac.sh) ---
models/*.gguf
models/_moved.gguf.bak

# --- Bundled llama.cpp runtime (binaries; fetched via scripts/setup_windows.ps1 or brew) ---
bin/

# --- Self-test artifacts (scripts/try_eva.py generates these on each run) ---
scripts/_eva_voice.wav
scripts/_eva_testbook.txt

# --- OS / editor noise ---
.DS_Store
*.log

# --- Vault backups (private data; created by seed/reset scripts) ---
local_vault.bak*/

# --- Skills CLI / agent tooling (machine-local, not project source) ---
.agents/
.claude/skills/
skills-lock.json
